{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "A musical note with pitch, timing and velocity",
      "type": "object",
      "properties": {
        "pitch": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "velocity": { "type": "number" }
      },
      "required": ["pitch", "time", "duration", "velocity"]
    },
    "SongSection": {
      "title": "SongSection",
      "description": "A section of a song like Verse or Chorus",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "durationBars": { "type": "number" }
      }
    },
    "Track": {
      "title": "Track",
      "description": "A generated musical track",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "genre": { "type": "string" },
        "mood": { "type": "string" },
        "instruments": { "type": "array", "items": { "type": "string" } },
        "bpm": { "type": "number" },
        "melody": { "type": "array", "items": { "$ref": "#/entities/Note" } },
        "bassline": { "type": "array", "items": { "$ref": "#/entities/Note" } },
        "chords": { "type": "array", "items": { "$ref": "#/entities/Note" } },
        "drums": { "type": "array", "items": { "$ref": "#/entities/Note" } },
        "structure": { "type": "array", "items": { "$ref": "#/entities/SongSection" } },
        "createdAt": { "type": "number" },
        "targetDuration": { "type": "number" },
        "lyrics": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["title", "description", "genre", "mood", "instruments", "bpm", "melody", "bassline", "chords", "createdAt", "userId"]
    }
  },
  "firestore": {
    "tracks/{trackId}": {
      "schema": "Track",
      "description": "Collection of music tracks generated by users"
    }
  }
}
